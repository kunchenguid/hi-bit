{
  "name": "hi-bit",
  "version": "0.0.4",
  "description": "Local-first Electron app where kids build web projects with Bit and an embedded Pi coding runtime.",
  "license": "MIT",
  "author": "Kun Chen",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "main": "./out/main/index.js",
  "scripts": {
    "preinstall": "node scripts/ensure-pnpm.mjs",
    "postinstall": "node scripts/copy-ort-assets.mjs",
    "predev": "node scripts/ensure-pnpm.mjs && node scripts/copy-ort-assets.mjs",
    "dev": "bash -c 'trap \"stty sane 2>/dev/null\" EXIT; electron-vite dev \"$@\"' --",
    "prebuild": "node scripts/ensure-pnpm.mjs && node scripts/copy-ort-assets.mjs",
    "build": "electron-vite build",
    "prestart": "node scripts/ensure-pnpm.mjs && node scripts/copy-ort-assets.mjs",
    "start": "electron-vite preview",
    "pretypecheck": "node scripts/ensure-pnpm.mjs",
    "typecheck": "tsc -b --pretty",
    "pretest": "node scripts/ensure-pnpm.mjs",
    "test": "vitest run",
    "pretest:watch": "node scripts/ensure-pnpm.mjs",
    "test:watch": "vitest",
    "prelint": "node scripts/ensure-pnpm.mjs",
    "lint": "biome lint .",
    "preformat": "node scripts/ensure-pnpm.mjs",
    "format": "biome format --write .",
    "precheck": "node scripts/ensure-pnpm.mjs",
    "check": "biome check .",
    "predist": "node scripts/ensure-pnpm.mjs",
    "dist": "electron-vite build && electron-builder",
    "prepackage:mac": "node scripts/ensure-pnpm.mjs",
    "package:mac": "rm -rf dist && pnpm build && electron-builder --mac dir --universal --config electron-builder.dev.yml",
    "predist:mac": "node scripts/ensure-pnpm.mjs",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "predist:win": "node scripts/ensure-pnpm.mjs",
    "dist:win": "electron-vite build && electron-builder --win",
    "predist:linux": "node scripts/ensure-pnpm.mjs",
    "dist:linux": "electron-vite build && electron-builder --linux",
    "predist:dir": "node scripts/ensure-pnpm.mjs",
    "dist:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.75.3",
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@mozilla/readability": "^0.6.0",
    "gifenc": "^1.0.3",
    "linkedom": "^0.18.12",
    "pngjs": "^7.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "turndown": "^7.2.4",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@huggingface/transformers": "^4.2.0",
    "@types/node": "^24.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^41.3.0",
    "electron-builder": "26.8.2",
    "electron-vite": "^5.0.0",
    "jsdom": "^28.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0"
  }
}
